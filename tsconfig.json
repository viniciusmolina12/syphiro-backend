{
  "compilerOptions": {
    "target": "ES2020",
    "module": "es2022",
    "rootDir": "src",
    "baseUrl": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true,
    "paths": {
      "@shared/*": ["./@shared/*"],
      "@character/*": ["./character/*"],
      "@class/*": ["./class/*"],
      "@combat/*": ["./combat/*"],
      "@enemy/*": ["./enemy/*"],
      "@instance/*": ["./instance/*"],
      "@player/*": ["./player/*"],
      "@profession/*": ["./profession/*"],
      "@skill/*": ["./skill/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
